{
  "name": "price-to-impact",
  "private": true,
  "version": "0.0.1",
  "description": "See every price as charity impact. A Habitual Genesis side project.",
  "author": "Habitual Genesis <https://github.com/habitualgenesis>",
  "license": "MIT",
  "homepage": "https://github.com/olitreadwell/price-to-impact",
  "repository": {
    "type": "git",
    "url": "https://github.com/olitreadwell/price-to-impact.git"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build:bookmarklet": "bun --filter='@price-to-impact/bookmarklet' run build",
    "predev": "bun run build:bookmarklet",
    "dev": "bun --filter='@price-to-impact/web' run dev",
    "prebuild": "bun run build:bookmarklet",
    "build": "bun --filter='@price-to-impact/web' run build",
    "lint": "bun --filter='*' run lint",
    "pretypecheck": "bun run build:bookmarklet",
    "typecheck": "bun --filter='*' run typecheck",
    "test": "bun --filter='*' run test"
  }
}
